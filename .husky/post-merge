git submodule update --init --recursive

git submodule foreach --recursive '
  echo "Submodule: $name (path: $path)"

  # If worktree has local changes, skip to avoid losing uncommitted work
  if [ -n "$(git status --porcelain)" ]; then
    echo "  -> working tree dirty, skipping"
    exit 0
  fi

  # Force checkout of main branch if available
  TARGET_BRANCH="main"
  echo "  -> target branch: $TARGET_BRANCH"

  if git show-ref --verify --quiet "refs/heads/$TARGET_BRANCH"; then
    git checkout "$TARGET_BRANCH" && git pull --ff-only origin "$TARGET_BRANCH" || echo "  -> pull failed or non-fast-forward; left as is"
  elif git ls-remote --exit-code --heads origin "$TARGET_BRANCH" >/dev/null 2>&1; then
    git checkout -b "$TARGET_BRANCH" origin/"$TARGET_BRANCH" || echo "  -> could not create tracking branch"
  else
    echo "  -> branch $TARGET_BRANCH not found locally or on origin, skipping"
  fi

  echo ""
'